{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@harmony/shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "../shared/node_modules"]
}
