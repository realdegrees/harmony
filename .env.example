# =============================================================================
# Harmony - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Default values below target local development (PostgreSQL and Redis running
# on localhost at their default ports, no Docker required).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Docker / remote:  postgresql://harmony:harmony@postgres:5432/harmony
DATABASE_URL=postgresql://harmony:harmony@localhost:5432/harmony

# Password used when provisioning the database (Docker compose / init scripts)
POSTGRES_PASSWORD=harmony

# -----------------------------------------------------------------------------
# Cache / Pub-Sub
# -----------------------------------------------------------------------------
# Docker / remote:  redis://redis:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# IMPORTANT: Replace with strong random strings before deploying anywhere.
# Minimum 32 characters recommended.
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Token lifetimes (ms-compatible duration strings)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
# Root path for uploaded files (relative to cwd, or absolute).
# Docker / production:  /data/uploads
STORAGE_PATH=./uploads

# Per-category upload limits
MAX_UPLOAD_SIZE_MB=50
MAX_EMOJI_SIZE_KB=256
MAX_SOUND_SIZE_MB=5
MAX_SOUND_DURATION_SECONDS=30
MAX_ATTACHMENT_SIZE_MB=25

# -----------------------------------------------------------------------------
# Messaging
# -----------------------------------------------------------------------------
DEFAULT_MESSAGE_LOAD_COUNT=100
MAX_MESSAGE_LENGTH=4000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# -----------------------------------------------------------------------------
# Giphy Integration (optional)
# -----------------------------------------------------------------------------
# Leave blank to disable GIF search.
GIPHY_API_KEY=

# -----------------------------------------------------------------------------
# Media Server (mediasoup / WebRTC)
# -----------------------------------------------------------------------------
# IP that mediasoup binds to on the server
MEDIASOUP_LISTEN_IP=0.0.0.0

# IP announced to WebRTC clients.
# Use your LAN/public IP for remote access; 127.0.0.1 is fine for local dev.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# UDP/TCP port range reserved for RTC streams
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100

# URL the backend uses to reach the media server.
# Docker / remote:  http://harmony-media:3001
MEDIA_SERVER_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Web Push Notifications (optional)
# -----------------------------------------------------------------------------
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Harmony
APP_URL=http://localhost:5173
PORT=3000
MEDIA_PORT=3001
