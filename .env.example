# ═══════════════════════════════════════
# Harmony Configuration
# ═══════════════════════════════════════

# ── Database ──────────────────────────
DATABASE_URL=postgresql://harmony:harmony@postgres:5432/harmony
POSTGRES_PASSWORD=harmony

# ── Redis ─────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ──────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Storage ───────────────────────────
STORAGE_PATH=/data/uploads
MAX_UPLOAD_SIZE_MB=50
MAX_EMOJI_SIZE_KB=256
MAX_SOUND_SIZE_MB=5
MAX_SOUND_DURATION_SECONDS=30
MAX_ATTACHMENT_SIZE_MB=25

# ── Messages ──────────────────────────
DEFAULT_MESSAGE_LOAD_COUNT=100
MAX_MESSAGE_LENGTH=4000

# ── Rate Limiting ─────────────────────
RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# ── Giphy ─────────────────────────────
GIPHY_API_KEY=your-giphy-api-key

# ── Voice / mediasoup ─────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
MEDIA_SERVER_URL=http://harmony-media:3001

# ── Push Notifications ────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ── App ───────────────────────────────
APP_NAME=Harmony
APP_URL=http://localhost
PORT=3000
MEDIA_PORT=3001
